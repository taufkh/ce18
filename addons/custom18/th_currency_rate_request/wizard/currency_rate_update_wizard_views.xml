<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_currency_rate_update_wizard_form" model="ir.ui.view">
        <field name="name">currency.rate.update.wizard.form</field>
        <field name="model">currency.rate.update.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Currency Rate">
                <group>
                    <field name="company_id"/>
                    <field name="currency_id"/>
                    <field name="request_date"/>
                </group>
                <footer>
                    <button name="action_update_currency_rate" string="Update" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
