        <field name="name">DMS directory report by department</field>
        <field name="model_id" ref="model_c18_dms_directory_department_report"/>
        <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('c18_dms.group_c18_dms_user'))]"/>
    </record>

    <record id="c18_dms_share_audit_report_rule" model="ir.rule">
        <field name="name">DMS share audit report by department</field>
        <field name="model_id" ref="model_c18_dms_share_audit_report"/>
