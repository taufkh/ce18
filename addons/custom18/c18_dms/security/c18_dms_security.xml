<odoo>
    <record id="group_c18_dms_user" model="res.groups">
        <field name="name">C18 DMS User</field>
        <field name="category_id" ref="base.module_category_productivity"/>
    </record>

    <record id="group_c18_dms_supervisor" model="res.groups">
        <field name="name">C18 DMS Supervisor</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('c18_dms.group_c18_dms_user'))]"/>
    </record>

    <record id="group_c18_dms_manager" model="res.groups">
        <field name="name">C18 DMS Manager</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('c18_dms.group_c18_dms_supervisor'))]"/>
    </record>

    <record id="group_c18_dms_executive" model="res.groups">
        <field name="name">C18 DMS Executive</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('c18_dms.group_c18_dms_manager'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="c18_dms_document_department_rule" model="ir.rule">
        <field name="name">DMS document by department</field>
        <field name="model_id" ref="model_c18_dms_document"/>
        <field name="domain_force">['|', '|', ('effective_department_id', '=', False), ('effective_department_id', 'in', user.employee_ids.department_id.ids), ('effective_user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('c18_dms.group_c18_dms_user'))]"/>
    </record>

    <record id="c18_dms_directory_department_rule" model="ir.rule">
        <field name="name">DMS directory by department</field>
        <field name="model_id" ref="model_c18_dms_directory"/>
        <field name="domain_force">['|', '|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.department_id.ids), ('user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('c18_dms.group_c18_dms_user'))]"/>
    </record>

    <record id="c18_dms_history_department_rule" model="ir.rule">
