        <field name="groups" eval="[(4, ref('c18_dms.group_c18_dms_user'))]"/>
    </record>

    <record id="c18_dms_share_log_department_rule" model="ir.rule">
        <field name="name">DMS share log by department</field>
        <field name="model_id" ref="model_c18_dms_share_log"/>
