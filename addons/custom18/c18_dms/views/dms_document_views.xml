<odoo>
    <record id="view_c18_dms_document_kanban" model="ir.ui.view">
        <field name="name">c18.dms.document.kanban</field>
        <field name="model">c18.dms.document</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="directory_id"/>
                <field name="project_id"/>
                <field name="doc_type_id"/>
                <field name="tag_ids"/>
                <field name="state"/>
                <field name="expiry_date"/>
                <field name="expiry_state"/>
                <field name="color"/>
                <field name="share_scope"/>
                <field name="public_share_status"/>
                <field name="history_count"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record d-flex flex-column p-3">
                            <div class="d-flex justify-content-between mb-2">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <field name="state" widget="badge"/>
                            </div>
                            <div class="mb-2">
                                <div>
                                    <field name="directory_id"/>
                                </div>
                                <div>
                                    <field name="project_id"/>
                                </div>
                                <div>
                                    <field name="doc_type_id"/>
                                </div>
                            </div>
                            <div class="mb-2">
                                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            </div>
                            <div class="d-flex flex-wrap gap-1 mb-2">
                                <span class="badge text-bg-light" t-if="record.directory_id.value">
                                    <i class="fa fa-folder-open me-1"/> <field name="directory_id"/>
                                </span>
                                <span class="badge text-bg-info" t-if="record.share_scope.raw_value == 'internal'">
                                    <i class="fa fa-users me-1"/> Internal Share
                                </span>
                                <span class="badge text-bg-warning" t-if="record.share_scope.raw_value == 'external'">
                                    <i class="fa fa-link me-1"/> External Share
                                </span>
                                <span class="badge text-bg-success" t-if="record.public_share_status.raw_value == 'active'">
                                    <i class="fa fa-shield me-1"/> Link Active
                                </span>
                                <span class="badge text-bg-warning" t-if="record.public_share_status.raw_value == 'expiring'">
                                    <i class="fa fa-hourglass-half me-1"/> Link Expiring
                                </span>
                                <span class="badge text-bg-danger" t-if="record.public_share_status.raw_value == 'expired'">
                                    <i class="fa fa-ban me-1"/> Link Expired
                                </span>
                                <span class="badge text-bg-secondary" t-if="record.history_count.raw_value">
                                    <i class="fa fa-history me-1"/> <field name="history_count"/> Revisions
                                </span>
                            </div>
                            <div t-attf-class="#{record.expiry_state.raw_value in ['warning', 'expired'] and 'text-danger fw-bold' or 'text-muted'}">
                                <field name="expiry_date"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_c18_dms_document_tree" model="ir.ui.view">
        <field name="name">c18.dms.document.tree</field>
        <field name="model">c18.dms.document</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="directory_id"/>
                <field name="project_id"/>
                <field name="doc_type_id"/>
                <field name="effective_department_id"/>
                <field name="state"/>
                <field name="expiry_date"/>
            </list>
        </field>
    </record>

    <record id="view_c18_dms_document_form" model="ir.ui.view">
        <field name="name">c18.dms.document.form</field>
        <field name="model">c18.dms.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_by_mail" type="object" string="Send by Mail"/>
                    <button name="action_submit_for_review" type="object" string="Submit for Review" invisible="state not in ('draft', 'rejected')"/>
                    <button name="action_approve_supervisor" type="object" string="Approve Supervisor" invisible="state not in ('in_review', 'supervisor_review')" class="btn-secondary"/>
                    <button name="action_approve_manager" type="object" string="Approve Manager" invisible="state not in ('manager_review',)" class="btn-primary"/>
                    <button name="action_reject_review" type="object" string="Reject" invisible="state not in ('in_review', 'supervisor_review', 'manager_review')" class="btn-secondary"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,supervisor_review,manager_review,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="directory_id"/>
                            <field name="department_id"/>
                            <field name="project_id"/>
                            <field name="doc_type_id"/>
                            <field name="review_sla_days"/>
                            <field name="supervisor_reviewer_id"/>
                            <field name="manager_reviewer_id"/>
                        </group>
                        <group>
                            <field name="attachment_id"/>
                            <field name="expiry_date"/>
                            <field name="expiry_state" readonly="1"/>
                            <field name="shared_user_ids" widget="many2many_tags"/>
                            <field name="shared_partner_ids" widget="many2many_tags"/>
                            <field name="review_deadline" readonly="1"/>
                            <field name="review_overdue" readonly="1"/>
                            <field name="lifecycle_status" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    </group>
                    <notebook>
                        <page string="Sharing">
                            <group>
                                <group>
                                    <field name="shared_user_ids" widget="many2many_tags"/>
                                    <field name="shared_partner_ids" widget="many2many_tags"/>
                                    <field name="allow_external_share"/>
                                    <field name="share_active_until" invisible="not allow_external_share"/>
                                    <field name="share_scope" readonly="1"/>
                                    <field name="public_share_status" readonly="1"/>
                                </group>
                                <group>
                                    <field name="share_url" readonly="1" widget="url"/>
                                    <field name="share_log_count" readonly="1"/>
                                    <button name="action_open_share_link" type="object" string="Open Share Link" class="btn-primary"/>
                                    <button name="action_regenerate_share_link" type="object" string="Regenerate Link"/>
                                    <button name="action_set_share_expiry_7d" type="object" string="Expire in 7 Days" class="btn-secondary"/>
                                    <button name="action_set_share_expiry_30d" type="object" string="Expire in 30 Days" class="btn-secondary"/>
                                    <button name="action_revoke_external_share" type="object" string="Revoke Share" class="btn-secondary" invisible="not allow_external_share"/>
                                </group>
                            </group>
                        </page>
                        <page string="Version History">
                            <field name="history_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="attachment_id"/>
                                    <field name="version_date"/>
                                    <field name="version_note"/>
                                    <button name="action_preview_attachment" type="object" string="Preview"/>
                                    <button name="action_download_attachment" type="object" string="Download"/>
                                </list>
                            </field>
                        </page>
                        <page string="Approval &amp; Lifecycle">
                            <group>
                                <group string="Approval Trail">
                                    <field name="submitted_by_id" readonly="1"/>
                                    <field name="submitted_date" readonly="1"/>
                                    <field name="supervisor_approved_by_id" readonly="1"/>
                                    <field name="supervisor_approved_date" readonly="1"/>
                                    <field name="manager_approved_by_id" readonly="1"/>
                                    <field name="manager_approved_date" readonly="1"/>
                                    <field name="rejected_by_id" readonly="1"/>
                                    <field name="rejected_date" readonly="1"/>
                                    <field name="reject_reason"/>
                                </group>
                                <group string="Review &amp; Retention">
                                    <field name="last_review_date" readonly="1"/>
                                    <field name="next_review_date" readonly="1"/>
                                    <field name="retention_due_date" readonly="1"/>
                                    <field name="last_sla_reminder_date" readonly="1"/>
                                    <field name="last_lifecycle_reminder_date" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Share Audit">
                            <field name="share_log_ids" readonly="1">
                                <list>
                                    <field name="accessed_at"/>
                                    <field name="access_type"/>
                                    <field name="access_ip"/>
                                    <field name="user_agent"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_c18_dms_document_search" model="ir.ui.view">
        <field name="name">c18.dms.document.search</field>
        <field name="model">c18.dms.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="directory_id"/>
                <field name="project_id"/>
                <field name="doc_type_id"/>
                <field name="department_id"/>
                <field name="shared_user_ids"/>
                <field name="shared_partner_ids"/>
                <field name="supervisor_reviewer_id"/>
                <field name="manager_reviewer_id"/>
                <filter name="filter_expiring" string="Expiring Soon" domain="[('expiry_state', '=', 'warning')]"/>
                <filter name="filter_expired" string="Expired" domain="[('expiry_state', '=', 'expired')]"/>
                <filter name="filter_review_overdue" string="Review Overdue" domain="[('review_overdue', '=', True)]"/>
                <filter name="filter_lifecycle_due" string="Lifecycle Due" domain="[('lifecycle_status', 'in', ['review_due', 'review_overdue', 'retention_due', 'retention_overdue'])]"/>
                <filter name="filter_pending_supervisor" string="Pending Supervisor" domain="[('state', 'in', ['in_review', 'supervisor_review'])]"/>
                <filter name="filter_pending_manager" string="Pending Manager" domain="[('state', '=', 'manager_review')]"/>
                <filter name="filter_shared" string="Shared With Me" domain="[('effective_user_ids', 'in', uid)]"/>
                <filter name="filter_public_share_active" string="Public Share Active" domain="[('public_share_status', '=', 'active')]"/>
                <filter name="filter_public_share_expiring" string="Public Share Expiring" domain="[('public_share_status', '=', 'expiring')]"/>
                <filter name="filter_public_share_revoked" string="Public Share Revoked" domain="[('public_share_status', 'in', ['inactive', 'expired'])]"/>
                <searchpanel>
                    <field name="directory_id" enable_counters="1" hierarchy="1"/>
                    <field name="doc_type_id" enable_counters="1"/>
                    <field name="state" enable_counters="1"/>
                </searchpanel>
                <group expand="0" string="Group By">
                    <filter name="group_by_directory" string="Directory" context="{'group_by': 'directory_id'}"/>
                    <filter name="group_by_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_by_type" string="Document Type" context="{'group_by': 'doc_type_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_lifecycle_status" string="Lifecycle Status" context="{'group_by': 'lifecycle_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_c18_dms_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">c18.dms.document</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_c18_dms_document_search"/>
    </record>

    <record id="action_c18_dms_my_documents" model="ir.actions.act_window">
        <field name="name">My Documents</field>
        <field name="res_model">c18.dms.document</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_c18_dms_document_search"/>
        <field name="domain">['|', ('create_uid', '=', uid), ('effective_user_ids', 'in', uid)]</field>
    </record>

    <record id="action_c18_dms_pending_supervisor_reviews" model="ir.actions.act_window">
        <field name="name">Pending Supervisor Reviews</field>
        <field name="res_model">c18.dms.document</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_c18_dms_document_search"/>
        <field name="domain">[('state', 'in', ['in_review', 'supervisor_review']), ('supervisor_reviewer_id', '=', uid)]</field>
    </record>

    <record id="action_c18_dms_pending_manager_reviews" model="ir.actions.act_window">
        <field name="name">Pending Manager Reviews</field>
        <field name="res_model">c18.dms.document</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_c18_dms_document_search"/>
        <field name="domain">[('state', '=', 'manager_review'), ('manager_reviewer_id', '=', uid)]</field>
    </record>

    <menuitem
        id="menu_c18_dms_document"
        name="Documents"
        parent="menu_c18_dms_operation"
        action="action_c18_dms_document"
        sequence="10"
    />

    <menuitem
        id="menu_c18_dms_my_documents"
        name="My Documents"
        parent="menu_c18_dms_operation"
        action="action_c18_dms_my_documents"
        sequence="8"
    />
</odoo>
