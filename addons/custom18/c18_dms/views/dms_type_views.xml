<odoo>
    <record id="view_c18_dms_type_tree" model="ir.ui.view">
        <field name="name">c18.dms.type.tree</field>
        <field name="model">c18.dms.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="default_review_sla_days"/>
                <field name="review_interval_days"/>
                <field name="retention_days"/>
                <field name="auto_archive_on_retention"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_c18_dms_type_form" model="ir.ui.view">
        <field name="name">c18.dms.type.form</field>
        <field name="model">c18.dms.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="default_review_sla_days"/>
                        <field name="review_interval_days"/>
                        <field name="retention_days"/>
                        <field name="auto_archive_on_retention"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_c18_dms_type" model="ir.actions.act_window">
        <field name="name">Document Types</field>
        <field name="res_model">c18.dms.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_c18_dms_type"
        name="Document Types"
        parent="menu_c18_dms_master"
        action="action_c18_dms_type"
        sequence="10"
    />
</odoo>
