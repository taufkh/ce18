<odoo>
    <record id="view_c18_dms_tag_tree" model="ir.ui.view">
        <field name="name">c18.dms.tag.tree</field>
        <field name="model">c18.dms.tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="color"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_c18_dms_tag_form" model="ir.ui.view">
        <field name="name">c18.dms.tag.form</field>
        <field name="model">c18.dms.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_c18_dms_tag" model="ir.actions.act_window">
        <field name="name">Document Tags</field>
        <field name="res_model">c18.dms.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_c18_dms_tag"
        name="Document Tags"
        parent="menu_c18_dms_master"
        action="action_c18_dms_tag"
        sequence="20"
    />
</odoo>
