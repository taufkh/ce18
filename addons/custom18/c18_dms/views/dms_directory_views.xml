<odoo>
    <record id="view_c18_dms_directory_tree" model="ir.ui.view">
        <field name="name">c18.dms.directory.tree</field>
        <field name="model">c18.dms.directory</field>
        <field name="arch" type="xml">
            <list>
                <field name="complete_name"/>
                <field name="department_id"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="document_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_c18_dms_directory_form" model="ir.ui.view">
        <field name="name">c18.dms.directory.form</field>
        <field name="model">c18.dms.directory</field>
        <field name="arch" type="xml">
            <form string="Document Directory">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="user_ids" widget="many2many_tags"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="document_count" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Documents">
                            <field name="document_ids" context="{'default_directory_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="doc_type_id"/>
                                    <field name="effective_department_id"/>
                                    <field name="state"/>
                                    <field name="expiry_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Subdirectories">
                            <field name="child_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="department_id"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_c18_dms_directory_search" model="ir.ui.view">
        <field name="name">c18.dms.directory.search</field>
        <field name="model">c18.dms.directory</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="department_id"/>
                <field name="user_ids"/>
                <field name="tag_ids"/>
                <filter name="filter_my_directories" string="My Directories" domain="[('user_ids', 'in', uid)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_parent" string="Parent Directory" context="{'group_by': 'parent_id'}"/>
                    <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_c18_dms_directory" model="ir.actions.act_window">
        <field name="name">Directories</field>
        <field name="res_model">c18.dms.directory</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_c18_dms_directory_search"/>
        <field name="context">{'search_default_group_by_parent': 1}</field>
    </record>

    <menuitem
        id="menu_c18_dms_directory"
        name="Directories"
        parent="menu_c18_dms_operation"
        action="action_c18_dms_directory"
        sequence="5"
    />
</odoo>
