<odoo>
    <record id="view_c18_dms_share_audit_export_wizard_form" model="ir.ui.view">
        <field name="name">c18.dms.share.audit.export.wizard.form</field>
        <field name="model">c18.dms.share.audit.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Share Audit">
                <sheet>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="export_format"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_export" type="object" string="Export" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_c18_dms_share_audit_export_wizard" model="ir.actions.act_window">
        <field name="name">Export Share Audit</field>
        <field name="res_model">c18.dms.share.audit.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_c18_dms_share_audit_export_wizard_form"/>
    </record>

    <menuitem
        id="menu_c18_dms_share_audit_export"
        name="Export Share Audit"
        parent="menu_c18_dms_dashboard"
        action="action_c18_dms_share_audit_export_wizard"
        sequence="26"
    />
</odoo>
