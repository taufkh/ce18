<odoo>
    <record id="view_c18_dms_share_token_wizard_form" model="ir.ui.view">
        <field name="name">c18.dms.share.token.wizard.form</field>
        <field name="model">c18.dms.share.token.wizard</field>
        <field name="arch" type="xml">
            <form string="Regenerate Share Tokens">
                <sheet>
                    <group>
                        <field name="mode"/>
                        <field name="document_ids" widget="many2many_tags" invisible="mode != 'selected'"/>
                        <field name="document_count" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_regenerate_tokens" type="object" string="Regenerate Tokens" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_c18_dms_share_token_wizard" model="ir.actions.act_window">
        <field name="name">Regenerate Share Tokens</field>
        <field name="res_model">c18.dms.share.token.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_c18_dms_share_token_wizard_form"/>
        <field name="context">{'default_document_ids': active_ids}</field>
    </record>

    <menuitem
        id="menu_c18_dms_share_token_wizard"
        name="Regenerate Share Tokens"
        parent="menu_c18_dms_master"
        action="action_c18_dms_share_token_wizard"
        sequence="30"
    />
</odoo>
