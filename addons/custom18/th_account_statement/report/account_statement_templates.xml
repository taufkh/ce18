<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_account_statement_template">
        <t t-call="web.html_container">
            <t t-set="all_data" t-value="doc.get_all_report_data()"/>
            <t t-foreach="all_data" t-as="data">
                <t t-call="web.internal_layout">
                    <div class="page">

                        <!-- ======= HEADER ======= -->
                        <div class="row mb-4">
                            <div class="col-7">
                                <t t-if="res_company.logo">
                                    <img t-att-src="image_data_uri(res_company.logo)"
                                         style="max-height:70px; max-width:200px; object-fit:contain;"/>
                                </t>
                                <div class="mt-2">
                                    <strong style="font-size:16px;">
                                        <t t-esc="res_company.name"/>
                                    </strong><br/>
                                    <span t-if="res_company.street">
                                        <t t-esc="res_company.street"/><br/>
                                    </span>
                                    <span t-if="res_company.city or res_company.zip">
                                        <t t-esc="res_company.zip"/> <t t-esc="res_company.city"/><br/>
                                    </span>
                                    <span t-if="res_company.phone">
                                        Tel: <t t-esc="res_company.phone"/><br/>
                                    </span>
                                    <span t-if="res_company.email">
                                        Email: <t t-esc="res_company.email"/>
                                    </span>
                                </div>
                            </div>
                            <div class="col-5 text-end">
                                <h2 style="color:#2c3e50; font-weight:700;">
                                    <t t-esc="data['statement_type_label']"/>
                                </h2>
                                <t t-if="data['date_from']">
                                    <p class="mb-1">
                                        <strong>Period: </strong>
                                        <t t-esc="data['date_from']" t-options='{"widget": "date"}'/>
                                        &amp;mdash;
                                        <t t-esc="data['date_to']" t-options='{"widget": "date"}'/>
                                    </p>
                                </t>
                                <t t-else="">
                                    <p class="mb-1"><strong>As of Date: </strong><t t-esc="context_timestamp(datetime.datetime.now())" t-options='{"widget": "date"}'/></p>
                                </t>
                            </div>
                        </div>

                        <hr style="border-top: 2px solid #2c3e50;"/>

                        <!-- ======= PARTNER INFO ======= -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h5 style="color:#555;">Statement For:</h5>
                                <strong><t t-esc="data['partner'].name"/></strong><br/>
                                <t t-if="data['partner'].street">
                                    <t t-esc="data['partner'].street"/><br/>
                                </t>
                                <t t-if="data['partner'].city or data['partner'].zip">
                                    <t t-esc="data['partner'].zip"/> <t t-esc="data['partner'].city"/><br/>
                                </t>
                                <t t-if="data['partner'].phone">
                                    Tel: <t t-esc="data['partner'].phone"/><br/>
                                </t>
                                <t t-if="data['partner'].email">
                                    Email: <t t-esc="data['partner'].email"/>
                                </t>
                            </div>
                            <div class="col-6 text-end">
                                <p><strong>Print Date: </strong><t t-esc="context_timestamp(datetime.datetime.now())" t-options='{"widget": "date"}'/></p>
                            </div>
                        </div>

                        <!-- ======= NO INVOICES ======= -->
                        <t t-if="not data['invoices']">
                            <div class="alert alert-info text-center">
                                No transactions found for this statement.
                            </div>
                        </t>

                        <!-- ======= INVOICE TABLE ======= -->
                        <t t-if="data['invoices']">
                            <table class="table table-sm table-bordered" style="font-size:12px;">
                                <thead style="background-color:#2c3e50; color:#fff;">
                                    <tr>
                                        <th style="width:10%;">Date</th>
                                        <th style="width:10%;">Due Date</th>
                                        <th style="width:20%;">Reference</th>
                                        <th style="width:20%;">Internal Ref</th>
                                        <th style="width:13%; text-align:right;">Amount</th>
                                        <th style="width:13%; text-align:right;">Paid</th>
                                        <th style="width:14%; text-align:right;">Balance Due</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td colspan="6" style="font-weight:bold;">Opening Balance</td>
                                        <td style="text-align:right; font-weight:bold;">
                                            <t t-esc="formatLang(data['opening_balance'], currency_obj=data['currency'])"/>
                                        </td>
                                    </tr>
                                    <t t-foreach="data['invoices']" t-as="line">
                                        <tr t-attf-style="background-color: {{ '#fff5f5' if line['is_refund'] else 'white' }}">
                                            <td>
                                                <t t-if="line['date']">
                                                    <t t-esc="line['date']" t-options='{"widget": "date"}'/>
                                                </t>
                                            </td>
                                            <td>
                                                <t t-if="line['due_date']">
                                                    <t t-esc="line['due_date']" t-options='{"widget": "date"}'/>
                                                </t>
                                            </td>
                                            <td><t t-esc="line['reference']"/></td>
                                            <td><t t-esc="line['ref']"/></td>
                                            <td style="text-align:right;">
                                                <t t-esc="formatLang(line['amount'], currency_obj=line['currency'])"/>
                                            </td>
                                            <td style="text-align:right;">
                                                <t t-esc="formatLang(line['paid'], currency_obj=line['currency'])"/>
                                            </td>
                                            <td style="text-align:right; font-weight:bold;">
                                                <t t-esc="formatLang(line['amount_due'], currency_obj=line['currency'])"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot style="background-color:#ecf0f1;">
                                    <tr>
                                        <td colspan="4" style="text-align:right; font-weight:bold;">TOTAL</td>
                                        <td style="text-align:right; font-weight:bold;">
                                            <t t-esc="formatLang(data['total_amount'], currency_obj=data['currency'])"/>
                                        </td>
                                        <td style="text-align:right; font-weight:bold;">
                                            <t t-esc="formatLang(data['total_paid'], currency_obj=data['currency'])"/>
                                        </td>
                                        <td style="text-align:right; font-weight:bold; color:#c0392b;">
                                            <t t-esc="formatLang(data['total_due'], currency_obj=data['currency'])"/>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- ======= AGEING SUMMARY ======= -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <h5 style="color:#2c3e50;">Ageing Summary (Outstanding Balance)</h5>
                                <table class="table table-sm table-bordered" style="font-size:12px;">
                                    <thead style="background-color:#34495e; color:#fff; text-align:center;">
                                        <tr>
                                            <th>Not Due</th>
                                            <th>1-30 Days</th>
                                            <th>31-60 Days</th>
                                            <th>61-90 Days</th>
                                            <th>91+ Days</th>
                                            <th>Total Outstanding</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr style="text-align:right;">
                                            <td>
                                                <t t-esc="formatLang(data['ageing']['not_due'], currency_obj=data['currency'])"/>
                                            </td>
                                            <td>
                                                <t t-esc="formatLang(data['ageing']['0_30'], currency_obj=data['currency'])"/>
                                            </td>
                                            <td>
                                                <t t-esc="formatLang(data['ageing']['31_60'], currency_obj=data['currency'])"/>
                                            </td>
                                            <td>
                                                <t t-esc="formatLang(data['ageing']['61_90'], currency_obj=data['currency'])"/>
                                            </td>
                                            <td style="color:#e74c3c;">
                                                <t t-esc="formatLang(data['ageing']['91_plus'], currency_obj=data['currency'])"/>
                                            </td>
                                            <td style="font-weight:bold; color:#c0392b;">
                                                <t t-esc="formatLang(data['ageing']['total'], currency_obj=data['currency'])"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- ======= FOOTER NOTE ======= -->
                        <div class="row mt-3">
                            <div class="col-12 text-center" style="font-size:11px; color:#777;">
                                <em>This statement is auto-generated. Please contact us if you have any discrepancies.</em>
                            </div>
                        </div>

                        <!-- Page break between partners (not last) -->
                        <t t-if="not data_last">
                            <div style="page-break-after: always;"/>
                        </t>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
