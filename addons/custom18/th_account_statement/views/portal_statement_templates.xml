<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_my_home_statement_entry" inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-set="show_stmt_menu" t-value="request.env['ir.config_parameter'].sudo().get_param('th_account_statement.show_statement_portal_menu', 'False') == 'True'"/>
            <t t-if="show_stmt_menu">
                <a class="list-group-item list-group-item-action d-flex align-items-center justify-content-between"
                   href="/my/customer_statements">
                    <span>Customer Statements</span>
                    <span class="fa fa-chevron-right"/>
                </a>
            </t>
        </xpath>
    </template>

    <template id="portal_customer_statements_page" name="Portal Customer Statements">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <div class="container mt-4 mb-5">
                <div class="row">
                    <div class="col-12">
                        <h3>Customer Statements</h3>
                        <t t-if="message">
                            <div class="alert alert-info mt-2">
                                <t t-esc="message"/>
                            </div>
                        </t>
                    </div>
                </div>

                <form action="/my/customer_statements" method="get" class="row g-3 mb-4 mt-2">
                    <div class="col-md-4">
                        <label class="form-label">From</label>
                        <input type="date" name="date_from" class="form-control"
                               t-att-value="date_from and date_from.strftime('%Y-%m-%d') or ''"/>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">To</label>
                        <input type="date" name="date_to" class="form-control"
                               t-att-value="date_to and date_to.strftime('%Y-%m-%d') or ''"/>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-primary" type="submit">Get Statement</button>
                    </div>
                </form>

                <h4>Customer Statements By Filter</h4>
                <div class="mb-3">
                    <form action="/my/customer_statements/send/filtered" method="post" style="display:inline;">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="date_from" t-att-value="date_from and date_from.strftime('%Y-%m-%d') or ''"/>
                        <input type="hidden" name="date_to" t-att-value="date_to and date_to.strftime('%Y-%m-%d') or ''"/>
                        <button type="submit" class="btn btn-outline-primary me-2">Send Filtered Statement</button>
                    </form>
                    <a t-att-href="'/my/customer_statements/download/filtered/pdf?date_from=%s&amp;date_to=%s' % (date_from.strftime('%Y-%m-%d'), date_to.strftime('%Y-%m-%d'))"
                       class="btn btn-outline-secondary me-2">Download Filtered Statement</a>
                    <a t-att-href="'/my/customer_statements/download/filtered/xlsx?date_from=%s&amp;date_to=%s' % (date_from.strftime('%Y-%m-%d'), date_to.strftime('%Y-%m-%d'))"
                       class="btn btn-outline-secondary">Download Filtered Statement XLS</a>
                </div>
                <div class="table-responsive mb-4">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Invoice Number</th>
                                <th>Invoice Date</th>
                                <th>Invoice Due Date</th>
                                <th class="text-end">Total Amount</th>
                                <th class="text-end">Paid Amount</th>
                                <th class="text-end">Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>Opening Balance</strong></td>
                                <td></td>
                                <td></td>
                                <td class="text-end">0.00</td>
                                <td class="text-end">0.00</td>
                                <td class="text-end"><t t-esc="opening_balance"/></td>
                            </tr>
                            <tr t-foreach="filtered_moves" t-as="mv">
                                <td><t t-esc="mv.name"/></td>
                                <td><t t-esc="mv.invoice_date"/></td>
                                <td><t t-esc="mv.invoice_date_due"/></td>
                                <td class="text-end"><t t-esc="mv.amount_total"/></td>
                                <td class="text-end"><t t-esc="mv.amount_total - mv.amount_residual"/></td>
                                <td class="text-end"><t t-esc="mv.amount_residual"/></td>
                            </tr>
                            <tr>
                                <td colspan="3"><strong>Total</strong></td>
                                <td class="text-end"><strong><t t-esc="filtered_totals['amount']"/></strong></td>
                                <td class="text-end"><strong><t t-esc="filtered_totals['paid']"/></strong></td>
                                <td class="text-end"><strong><t t-esc="filtered_totals['balance']"/></strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <h4>Customer Statements</h4>
                <div class="mb-3">
                    <form action="/my/customer_statements/send/normal" method="post" style="display:inline;">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="date_from" t-att-value="date_from and date_from.strftime('%Y-%m-%d') or ''"/>
                        <input type="hidden" name="date_to" t-att-value="date_to and date_to.strftime('%Y-%m-%d') or ''"/>
                        <button type="submit" class="btn btn-outline-primary me-2">Send Statement</button>
                    </form>
                    <a href="/my/customer_statements/download/normal/pdf" class="btn btn-outline-secondary me-2">Download Statement</a>
                    <a href="/my/customer_statements/download/normal/xlsx" class="btn btn-outline-secondary">Download Statement XLS</a>
                </div>
                <div class="table-responsive mb-4">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Invoice Number</th>
                                <th>Invoice Date</th>
                                <th>Invoice Due Date</th>
                                <th class="text-end">Total Amount</th>
                                <th class="text-end">Paid Amount</th>
                                <th class="text-end">Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="normal_moves" t-as="mv">
                                <td><t t-esc="mv.name"/></td>
                                <td><t t-esc="mv.invoice_date"/></td>
                                <td><t t-esc="mv.invoice_date_due"/></td>
                                <td class="text-end"><t t-esc="mv.amount_total"/></td>
                                <td class="text-end"><t t-esc="mv.amount_total - mv.amount_residual"/></td>
                                <td class="text-end"><t t-esc="mv.amount_residual"/></td>
                            </tr>
                            <tr>
                                <td colspan="3"><strong>Total</strong></td>
                                <td class="text-end"><strong><t t-esc="normal_totals['amount']"/></strong></td>
                                <td class="text-end"><strong><t t-esc="normal_totals['paid']"/></strong></td>
                                <td class="text-end"><strong><t t-esc="normal_totals['balance']"/></strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <h4>Overdue Statements</h4>
                <div class="mb-3">
                    <form action="/my/customer_statements/send/overdue" method="post" style="display:inline;">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="date_from" t-att-value="date_from and date_from.strftime('%Y-%m-%d') or ''"/>
                        <input type="hidden" name="date_to" t-att-value="date_to and date_to.strftime('%Y-%m-%d') or ''"/>
                        <button type="submit" class="btn btn-outline-primary me-2">Send Overdue Statement</button>
                    </form>
                    <a href="/my/customer_statements/download/overdue/pdf" class="btn btn-outline-secondary me-2">Download Overdue Statement</a>
                    <a href="/my/customer_statements/download/overdue/xlsx" class="btn btn-outline-secondary">Download Overdue Statement XLS</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Invoice Number</th>
                                <th>Invoice Date</th>
                                <th>Invoice Due Date</th>
                                <th class="text-end">Total Amount</th>
                                <th class="text-end">Paid Amount</th>
                                <th class="text-end">Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="overdue_moves" t-as="mv">
                                <td><t t-esc="mv.name"/></td>
                                <td><t t-esc="mv.invoice_date"/></td>
                                <td><t t-esc="mv.invoice_date_due"/></td>
                                <td class="text-end"><t t-esc="mv.amount_total"/></td>
                                <td class="text-end"><t t-esc="mv.amount_total - mv.amount_residual"/></td>
                                <td class="text-end"><t t-esc="mv.amount_residual"/></td>
                            </tr>
                            <tr>
                                <td colspan="3"><strong>Total</strong></td>
                                <td class="text-end"><strong><t t-esc="overdue_totals['amount']"/></strong></td>
                                <td class="text-end"><strong><t t-esc="overdue_totals['paid']"/></strong></td>
                                <td class="text-end"><strong><t t-esc="overdue_totals['balance']"/></strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <h5 class="mt-4">Ageing Summary</h5>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>0-30 Days</th>
                                <th>31-60 Days</th>
                                <th>61-90 Days</th>
                                <th>90+ Days</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><t t-esc="ageing['0_30']"/></td>
                                <td><t t-esc="ageing['31_60']"/></td>
                                <td><t t-esc="ageing['61_90']"/></td>
                                <td><t t-esc="ageing['91_plus']"/></td>
                                <td><strong><t t-esc="ageing['total']"/></strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_shared_statement_page" name="Public Shared Statement">
        <t t-call="web.layout">
            <style>
                .th-statement-wrap { max-width: 1240px; margin: 32px auto 56px; padding: 0 16px; font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; color: #1f2d3d; }
                .th-statement-card { background: #ffffff; border: 1px solid #dfe5ec; border-radius: 10px; box-shadow: 0 8px 24px rgba(26, 37, 47, 0.08); overflow: hidden; }
                .th-header { background: linear-gradient(135deg, #2c3e50, #34495e); color: #fff; padding: 24px; }
                .th-header h2 { margin: 0 0 8px; font-size: 28px; }
                .th-meta { font-size: 14px; opacity: 0.95; }
                .th-body { padding: 20px 24px 28px; }
                .th-filter { display: flex; gap: 12px; align-items: end; flex-wrap: wrap; margin-bottom: 18px; }
                .th-field { display: flex; flex-direction: column; min-width: 180px; }
                .th-field label { font-size: 12px; font-weight: 600; color: #425466; margin-bottom: 6px; text-transform: uppercase; letter-spacing: .03em; }
                .th-field input { border: 1px solid #cfd8e3; border-radius: 6px; padding: 8px 10px; font-size: 14px; }
                .th-btn { border-radius: 6px; padding: 9px 14px; text-decoration: none; display: inline-block; font-weight: 600; border: 1px solid transparent; }
                .th-btn-primary { background: #2c3e50; color: #fff; }
                .th-btn-outline { border-color: #9db1c5; color: #2c3e50; background: #fff; }
                .th-actions { margin: 10px 0 16px; display: flex; gap: 10px; flex-wrap: wrap; }
                .th-section-title { margin: 20px 0 10px; font-size: 20px; color: #2c3e50; }
                .th-table { width: 100%; border-collapse: collapse; font-size: 14px; }
                .th-table th { background: #34495e; color: #fff; padding: 10px; border: 1px solid #2a3a4a; text-align: left; }
                .th-table td { padding: 10px; border: 1px solid #d7dee6; background: #fff; }
                .th-table .num { text-align: right; font-variant-numeric: tabular-nums; }
                .th-table .total-row td { background: #eff3f6; font-weight: 700; }
                .th-table .opening-row td { background: #f8fafc; font-weight: 600; }
                .th-grid { display: grid; grid-template-columns: repeat(3, minmax(190px, 1fr)); gap: 10px; margin-bottom: 14px; }
                .th-kpi { border: 1px solid #dbe3ec; border-radius: 8px; padding: 12px; background: #fafcff; }
                .th-kpi .lbl { font-size: 11px; text-transform: uppercase; color: #607287; letter-spacing: .04em; margin-bottom: 4px; }
                .th-kpi .val { font-size: 22px; font-weight: 700; color: #243546; }
                .th-ageing td { text-align: right; font-variant-numeric: tabular-nums; }
                @media (max-width: 820px) {
                    .th-grid { grid-template-columns: 1fr; }
                    .th-header h2 { font-size: 22px; }
                    .th-body { padding: 16px; }
                    .th-table { font-size: 13px; }
                }
            </style>

            <div class="th-statement-wrap">
                <div class="th-statement-card">
                    <div class="th-header">
                        <h2>Statement of Account</h2>
                        <div class="th-meta">
                            Partner: <strong><t t-esc="partner.name"/></strong><br/>
                            Date: <t t-esc="date_from" t-options='{"widget": "date"}'/> - <t t-esc="date_to" t-options='{"widget": "date"}'/>
                        </div>
                    </div>

                    <div class="th-body">
                        <form t-att-action="'/statement/share/%s' % partner.id" method="get" class="th-filter">
                            <input type="hidden" name="token" t-att-value="token"/>
                            <div class="th-field">
                                <label>From</label>
                                <input type="date" name="date_from"
                                       t-att-value="date_from and date_from.strftime('%Y-%m-%d') or ''"/>
                            </div>
                            <div class="th-field">
                                <label>To</label>
                                <input type="date" name="date_to"
                                       t-att-value="date_to and date_to.strftime('%Y-%m-%d') or ''"/>
                            </div>
                            <div>
                                <button class="th-btn th-btn-primary" type="submit">Get Statement</button>
                            </div>
                        </form>

                        <div class="th-grid">
                            <div class="th-kpi">
                                <div class="lbl">Opening Balance</div>
                                <div class="val">
                                    <t t-esc="opening_balance" t-options='{"widget": "monetary", "display_currency": currency}'/>
                                </div>
                            </div>
                            <div class="th-kpi">
                                <div class="lbl">Total In Period</div>
                                <div class="val">
                                    <t t-esc="filtered_totals['amount']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                                </div>
                            </div>
                            <div class="th-kpi">
                                <div class="lbl">Outstanding</div>
                                <div class="val">
                                    <t t-esc="filtered_totals['balance']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                                </div>
                            </div>
                        </div>

                        <h3 class="th-section-title">Customer Statements By Filter</h3>
                        <div class="th-actions">
                            <a t-att-href="'/statement/share/%s/download/filtered/pdf?token=%s&amp;date_from=%s&amp;date_to=%s' % (partner.id, token, date_from.strftime('%Y-%m-%d'), date_to.strftime('%Y-%m-%d'))"
                               class="th-btn th-btn-outline">View Filtered Statement PDF</a>
                            <a t-att-href="'/statement/share/%s/download/filtered/xlsx?token=%s&amp;date_from=%s&amp;date_to=%s' % (partner.id, token, date_from.strftime('%Y-%m-%d'), date_to.strftime('%Y-%m-%d'))"
                               class="th-btn th-btn-outline">Download Filtered Statement XLS</a>
                        </div>

                        <div style="overflow-x:auto;">
                            <table class="th-table">
                                <thead>
                                    <tr>
                                        <th>Invoice Number</th>
                                        <th>Invoice Date</th>
                                        <th>Due Date</th>
                                        <th class="num">Total Amount</th>
                                        <th class="num">Paid Amount</th>
                                        <th class="num">Balance</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="opening-row">
                                        <td>Opening Balance</td>
                                        <td/>
                                        <td/>
                                        <td class="num"><t t-esc="0.0" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td class="num"><t t-esc="0.0" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td class="num"><t t-esc="opening_balance" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                    </tr>
                                    <tr t-foreach="filtered_moves" t-as="mv">
                                        <td><t t-esc="mv.name"/></td>
                                        <td><t t-esc="mv.invoice_date" t-options='{"widget": "date"}'/></td>
                                        <td><t t-esc="mv.invoice_date_due" t-options='{"widget": "date"}'/></td>
                                        <td class="num"><t t-esc="mv.amount_total" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td class="num"><t t-esc="mv.amount_total - mv.amount_residual" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td class="num"><t t-esc="mv.amount_residual" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                    </tr>
                                    <tr class="total-row">
                                        <td colspan="3">Total</td>
                                        <td class="num"><t t-esc="filtered_totals['amount']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td class="num"><t t-esc="filtered_totals['paid']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td class="num"><t t-esc="filtered_totals['balance']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <h3 class="th-section-title">Ageing Summary</h3>
                        <div style="overflow-x:auto;">
                            <table class="th-table th-ageing">
                                <thead>
                                    <tr>
                                        <th>0-30 Days</th>
                                        <th>31-60 Days</th>
                                        <th>61-90 Days</th>
                                        <th>91+ Days</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="total-row">
                                        <td><t t-esc="ageing['0_30']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td><t t-esc="ageing['31_60']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td><t t-esc="ageing['61_90']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td><t t-esc="ageing['91_plus']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                        <td><t t-esc="ageing['total']" t-options='{"widget": "monetary", "display_currency": currency}'/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <h3 class="th-section-title">Download Full Statements</h3>
                        <div class="th-actions">
                            <a t-att-href="'/statement/share/%s/download/normal/pdf?token=%s' % (partner.id, token)" class="th-btn th-btn-outline">View Statement PDF</a>
                            <a t-att-href="'/statement/share/%s/download/normal/xlsx?token=%s' % (partner.id, token)" class="th-btn th-btn-outline">Download Statement XLS</a>
                            <a t-att-href="'/statement/share/%s/download/overdue/pdf?token=%s' % (partner.id, token)" class="th-btn th-btn-outline">View Overdue PDF</a>
                            <a t-att-href="'/statement/share/%s/download/overdue/xlsx?token=%s' % (partner.id, token)" class="th-btn th-btn-outline">Download Overdue XLS</a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
