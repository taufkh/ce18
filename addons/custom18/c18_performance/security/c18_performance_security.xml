<odoo>
    <record id="group_c18_performance_user" model="res.groups">
        <field name="name">C18 Performance User</field>
        <field name="category_id" ref="base.module_category_productivity"/>
    </record>

    <record id="group_c18_performance_manager" model="res.groups">
        <field name="name">C18 Performance Manager</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('c18_performance.group_c18_performance_user'))]"/>
    </record>

    <record id="group_c18_performance_executive" model="res.groups">
        <field name="name">C18 Performance Executive</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('c18_performance.group_c18_performance_manager'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="c18_performance_objective_department_rule" model="ir.rule">
        <field name="name">Performance objective by department</field>
        <field name="model_id" ref="model_c18_okr_objective"/>
        <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('c18_performance.group_c18_performance_user'))]"/>
    </record>

    <record id="c18_performance_kpi_department_rule" model="ir.rule">
        <field name="name">Performance KPI by department</field>
        <field name="model_id" ref="model_c18_okr_kpi"/>
        <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('c18_performance.group_c18_performance_user'))]"/>
    </record>

    <record id="c18_performance_checkin_department_rule" model="ir.rule">
        <field name="name">Performance check-in by department</field>
        <field name="model_id" ref="model_c18_kpi_checkin"/>
        <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('c18_performance.group_c18_performance_user'))]"/>
    </record>

    <record id="c18_performance_report_department_rule" model="ir.rule">
        <field name="name">Performance report by department</field>
        <field name="model_id" ref="model_c18_performance_kpi_status_report"/>
        <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('c18_performance.group_c18_performance_user'))]"/>
    </record>

    <record id="c18_performance_department_summary_rule" model="ir.rule">
        <field name="name">Performance department summary by department</field>
        <field name="model_id" ref="model_c18_performance_department_report"/>
        <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('c18_performance.group_c18_performance_user'))]"/>
    </record>

    <record id="c18_performance_cycle_scorecard_rule" model="ir.rule">
        <field name="name">Performance cycle scorecard by department scope</field>
        <field name="model_id" ref="model_c18_performance_cycle_scorecard_report"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('c18_performance.group_c18_performance_user'))]"/>
    </record>

    <record id="c18_performance_owner_scorecard_rule" model="ir.rule">
        <field name="name">Performance owner scorecard by department</field>
        <field name="model_id" ref="model_c18_performance_owner_scorecard_report"/>
        <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'in', user.employee_ids.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('c18_performance.group_c18_performance_user'))]"/>
    </record>
</odoo>
