<odoo>
    <record id="view_c18_kpi_target_line_tree" model="ir.ui.view">
        <field name="name">c18.kpi.target.line.tree</field>
        <field name="model">c18.kpi.target.line</field>
        <field name="arch" type="xml">
            <list editable="bottom" default_order="period_date asc">
                <field name="period_date"/>
                <field name="target_value"/>
                <field name="weight"/>
                <field name="note"/>
            </list>
        </field>
    </record>
</odoo>
