<odoo>
    <record id="view_c18_okr_cycle_tree" model="ir.ui.view">
        <field name="name">c18.okr.cycle.tree</field>
        <field name="model">c18.okr.cycle</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="period_type"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="review_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_c18_okr_cycle_form" model="ir.ui.view">
        <field name="name">c18.okr.cycle.form</field>
        <field name="model">c18.okr.cycle</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_cycle" type="object" string="Open" invisible="state != 'draft'"/>
                    <button name="action_lock_cycle" type="object" string="Lock" invisible="state != 'open'"/>
                    <button name="action_close_cycle" type="object" string="Close" invisible="state != 'locked'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,locked,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="period_type"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="review_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Objectives">
                            <field name="objective_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_c18_okr_cycle" model="ir.actions.act_window">
        <field name="name">Cycles</field>
        <field name="res_model">c18.okr.cycle</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_c18_okr_cycle"
        name="Cycles"
        parent="menu_c18_performance_master"
        action="action_c18_okr_cycle"
        sequence="5"
    />
</odoo>
