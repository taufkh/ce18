<odoo>
    <record id="view_c18_bsc_perspective_tree" model="ir.ui.view">
        <field name="name">c18.bsc.perspective.tree</field>
        <field name="model">c18.bsc.perspective</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_c18_bsc_perspective_form" model="ir.ui.view">
        <field name="name">c18.bsc.perspective.form</field>
        <field name="model">c18.bsc.perspective</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_c18_bsc_perspective" model="ir.actions.act_window">
        <field name="name">BSC Perspectives</field>
        <field name="res_model">c18.bsc.perspective</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_c18_bsc_perspective"
        name="BSC Perspectives"
        parent="menu_c18_performance_master"
        action="action_c18_bsc_perspective"
        sequence="10"
    />
</odoo>
