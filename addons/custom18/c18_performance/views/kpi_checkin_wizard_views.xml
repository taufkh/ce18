<odoo>
    <record id="view_c18_kpi_checkin_wizard_form" model="ir.ui.view">
        <field name="name">c18.kpi.checkin.wizard.form</field>
        <field name="model">c18.kpi.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Quick Check-in">
                <sheet>
                    <group>
                        <group>
                            <field name="kpi_id" readonly="1"/>
                            <field name="objective_id" readonly="1"/>
                            <field name="cycle_id" readonly="1"/>
                            <field name="owner_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="department_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="current_actual_value" readonly="1"/>
                            <field name="target_value" readonly="1"/>
                            <field name="current_target_value" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="name"/>
                        <field name="actual_value"/>
                        <field name="checkin_date"/>
                        <field name="period_date"/>
                        <field name="evidence_attachment_ids" widget="many2many_binary"/>
                        <field name="note"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_submit_checkin" type="object" string="Submit Check-in" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
