<odoo>
    <record id="view_c18_performance_kpi_status_graph" model="ir.ui.view">
        <field name="name">c18.performance.kpi.status.report.graph</field>
        <field name="model">c18.performance.kpi.status.report</field>
        <field name="arch" type="xml">
            <graph string="Company Health" type="pie">
                <field name="rag_status" type="row"/>
                <field name="kpi_count" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_c18_performance_kpi_status_pivot" model="ir.ui.view">
        <field name="name">c18.performance.kpi.status.report.pivot</field>
        <field name="model">c18.performance.kpi.status.report</field>
        <field name="arch" type="xml">
            <pivot string="Company Health">
                <field name="cycle_id" type="row"/>
                <field name="department_id" type="row"/>
                <field name="rag_status" type="col"/>
                <field name="kpi_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_c18_performance_company_health" model="ir.actions.act_window">
        <field name="name">Company Health</field>
        <field name="res_model">c18.performance.kpi.status.report</field>
        <field name="view_mode">graph,pivot</field>
    </record>

    <record id="view_c18_performance_department_progress_graph" model="ir.ui.view">
        <field name="name">c18.performance.department.report.graph</field>
        <field name="model">c18.performance.department.report</field>
        <field name="arch" type="xml">
            <graph string="Department Leaderboard" type="bar">
                <field name="department_id" type="row"/>
                <field name="total_progress" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_c18_performance_department_progress_pivot" model="ir.ui.view">
        <field name="name">c18.performance.department.report.pivot</field>
        <field name="model">c18.performance.department.report</field>
        <field name="arch" type="xml">
            <pivot string="Department Leaderboard">
                <field name="cycle_id" type="row"/>
                <field name="department_id" type="row"/>
                <field name="objective_scope" type="col"/>
                <field name="total_progress" type="measure"/>
                <field name="objective_count" type="measure"/>
                <field name="kpi_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_c18_performance_department_leaderboard" model="ir.actions.act_window">
        <field name="name">Department Leaderboard</field>
        <field name="res_model">c18.performance.department.report</field>
        <field name="view_mode">pivot,graph</field>
    </record>

    <record id="view_c18_performance_cycle_scorecard_graph" model="ir.ui.view">
        <field name="name">c18.performance.cycle.scorecard.report.graph</field>
        <field name="model">c18.performance.cycle.scorecard.report</field>
        <field name="arch" type="xml">
            <graph string="Cycle Scorecard" type="bar">
                <field name="cycle_id" type="row"/>
                <field name="avg_progress" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_c18_performance_cycle_scorecard_pivot" model="ir.ui.view">
        <field name="name">c18.performance.cycle.scorecard.report.pivot</field>
        <field name="model">c18.performance.cycle.scorecard.report</field>
        <field name="arch" type="xml">
            <pivot string="Cycle Scorecard">
                <field name="cycle_id" type="row"/>
                <field name="objective_scope" type="col"/>
                <field name="avg_progress" type="measure"/>
                <field name="objective_count" type="measure"/>
                <field name="red_kpi_count" type="measure"/>
                <field name="green_kpi_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_c18_performance_cycle_scorecard" model="ir.actions.act_window">
        <field name="name">Cycle Scorecard</field>
        <field name="res_model">c18.performance.cycle.scorecard.report</field>
        <field name="view_mode">pivot,graph</field>
    </record>

    <record id="view_c18_performance_owner_scorecard_graph" model="ir.ui.view">
        <field name="name">c18.performance.owner.scorecard.report.graph</field>
        <field name="model">c18.performance.owner.scorecard.report</field>
        <field name="arch" type="xml">
            <graph string="Owner Scorecard" type="bar">
                <field name="owner_id" type="row"/>
                <field name="avg_progress" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_c18_performance_owner_scorecard_pivot" model="ir.ui.view">
        <field name="name">c18.performance.owner.scorecard.report.pivot</field>
        <field name="model">c18.performance.owner.scorecard.report</field>
        <field name="arch" type="xml">
            <pivot string="Owner Scorecard">
                <field name="cycle_id" type="row"/>
                <field name="owner_id" type="row"/>
                <field name="objective_scope" type="col"/>
                <field name="avg_progress" type="measure"/>
                <field name="achievement_rate" type="measure"/>
                <field name="objective_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_c18_performance_owner_scorecard" model="ir.actions.act_window">
        <field name="name">Owner Scorecard</field>
        <field name="res_model">c18.performance.owner.scorecard.report</field>
        <field name="view_mode">pivot,graph</field>
    </record>

    <record id="action_c18_okr_kpi_red" model="ir.actions.act_window">
        <field name="name">Red KPIs</field>
        <field name="res_model">c18.okr.kpi</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('rag_status', '=', 'red')]</field>
    </record>

    <record id="action_c18_okr_objective_by_department" model="ir.actions.act_window">
        <field name="name">Objectives by Department</field>
        <field name="res_model">c18.okr.objective</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'group_by': 'department_id'}</field>
    </record>

    <record id="view_c18_performance_operations_board" model="ir.ui.view">
        <field name="name">c18.performance.operations.board</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Performance Operations Dashboard">
                <board style="2-1">
                    <column>
                        <action name="%(action_c18_my_okr_objective)d" string="My Objectives" view_mode="list"/>
                        <action name="%(action_c18_my_okr_kpi)d" string="My KPIs" view_mode="list"/>
                        <action name="%(action_c18_okr_objective_by_department)d" string="Objectives by Department" view_mode="list"/>
                    </column>
                    <column>
                        <action name="%(action_c18_my_kpi_checkin)d" string="My Check-ins" view_mode="list"/>
                        <action name="%(action_c18_okr_kpi_overdue)d" string="Overdue Check-ins" view_mode="list"/>
                        <action name="%(action_c18_okr_kpi_red)d" string="Red KPIs" view_mode="list"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="view_c18_performance_staff_board" model="ir.ui.view">
        <field name="name">c18.performance.staff.board</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Performance Staff Dashboard">
                <board style="2-1">
                    <column>
                        <action name="%(action_c18_my_okr_objective)d" string="My Objectives" view_mode="list"/>
                        <action name="%(action_c18_my_okr_kpi)d" string="My KPIs" view_mode="list"/>
                    </column>
                    <column>
                        <action name="%(action_c18_my_kpi_checkin)d" string="My Check-ins" view_mode="list"/>
                        <action name="%(action_c18_okr_kpi_overdue)d" string="Overdue Check-ins" view_mode="list"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="view_c18_performance_manager_board" model="ir.ui.view">
        <field name="name">c18.performance.manager.board</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Performance Manager Dashboard">
                <board style="2-1">
                    <column>
                        <action name="%(action_c18_department_okr_objective)d" string="My Department Objectives" view_mode="list"/>
                        <action name="%(action_c18_department_okr_kpi)d" string="My Department KPIs" view_mode="list"/>
                    </column>
                    <column>
                        <action name="%(action_c18_department_kpi_checkin)d" string="My Department Check-ins" view_mode="list"/>
                        <action name="%(action_c18_pending_kpi_checkin)d" string="Pending Approval" view_mode="list"/>
                        <action name="%(action_c18_rejected_kpi_checkin)d" string="Rejected Check-ins" view_mode="list"/>
                        <action name="%(action_c18_okr_kpi_overdue)d" string="Overdue Check-ins" view_mode="list"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_c18_performance_operations_board" model="ir.actions.act_window">
        <field name="name">Operations Board</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="view_id" ref="view_c18_performance_operations_board"/>
    </record>

    <record id="action_c18_performance_staff_board" model="ir.actions.act_window">
        <field name="name">Staff Board</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="view_id" ref="view_c18_performance_staff_board"/>
    </record>

    <record id="action_c18_performance_manager_board" model="ir.actions.act_window">
        <field name="name">Manager Board</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="view_id" ref="view_c18_performance_manager_board"/>
    </record>

    <record id="view_c18_performance_executive_board" model="ir.ui.view">
        <field name="name">c18.performance.executive.board</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Performance Executive Dashboard">
                <board style="2-1">
                    <column>
                        <action name="%(action_c18_performance_company_health)d" string="Company Health" view_mode="graph"/>
                        <action name="%(action_c18_performance_cycle_scorecard)d" string="Cycle Scorecard" view_mode="pivot"/>
                    </column>
                    <column>
                        <action name="%(action_c18_okr_hierarchy)d" string="Hierarchy Chart" view_mode="kanban"/>
                        <action name="%(action_c18_performance_owner_scorecard)d" string="Owner Scorecard" view_mode="pivot"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_c18_performance_executive_board" model="ir.actions.act_window">
        <field name="name">Executive Board</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="view_id" ref="view_c18_performance_executive_board"/>
    </record>

    <record id="menu_c18_performance_root" model="ir.ui.menu">
        <field name="action" eval="'ir.actions.act_window,%d' % ref('action_c18_okr_objective')"/>
    </record>

    <menuitem
        id="menu_c18_performance_executive_board"
        name="Executive Board"
        parent="menu_c18_performance_dashboard"
        action="action_c18_performance_executive_board"
        sequence="5"
        groups="c18_performance.group_c18_performance_executive"
    />

    <menuitem
        id="menu_c18_performance_operations_board"
        name="Operations Board"
        parent="menu_c18_performance_dashboard"
        action="action_c18_performance_operations_board"
        sequence="8"
        groups="c18_performance.group_c18_performance_manager,c18_performance.group_c18_performance_executive"
    />

    <menuitem
        id="menu_c18_performance_staff_board"
        name="Staff Board"
        parent="menu_c18_performance_dashboard"
        action="action_c18_performance_staff_board"
        sequence="6"
        groups="c18_performance.group_c18_performance_user"
    />

    <menuitem
        id="menu_c18_performance_manager_board"
        name="Manager Board"
        parent="menu_c18_performance_dashboard"
        action="action_c18_performance_manager_board"
        sequence="7"
        groups="c18_performance.group_c18_performance_manager,c18_performance.group_c18_performance_executive"
    />

    <menuitem
        id="menu_c18_performance_company_health"
        name="Company Health"
        parent="menu_c18_performance_dashboard"
        action="action_c18_performance_company_health"
        sequence="10"
    />

    <menuitem
        id="menu_c18_performance_cycle_scorecard"
        name="Cycle Scorecard"
        parent="menu_c18_performance_dashboard"
        action="action_c18_performance_cycle_scorecard"
        sequence="15"
    />

    <menuitem
        id="menu_c18_performance_department_leaderboard"
        name="Department Leaderboard"
        parent="menu_c18_performance_dashboard"
        action="action_c18_performance_department_leaderboard"
        sequence="20"
    />

    <menuitem
        id="menu_c18_performance_owner_scorecard"
        name="Owner Scorecard"
        parent="menu_c18_performance_dashboard"
        action="action_c18_performance_owner_scorecard"
        sequence="25"
    />

    <record id="action_c18_demo_users" model="ir.actions.act_window">
        <field name="name">Demo Users</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('login', '=like', 'c18.%')]</field>
    </record>

    <record id="action_c18_demo_groups" model="ir.actions.act_window">
        <field name="name">C18 Groups</field>
        <field name="res_model">res.groups</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('name', 'ilike', 'C18 ')]</field>
    </record>

    <menuitem
        id="menu_c18_demo_users"
        name="Demo Users"
        parent="menu_c18_performance_config"
        action="action_c18_demo_users"
        sequence="10"
    />

    <menuitem
        id="menu_c18_demo_groups"
        name="Access Groups"
        parent="menu_c18_performance_config"
        action="action_c18_demo_groups"
        sequence="20"
    />
</odoo>
