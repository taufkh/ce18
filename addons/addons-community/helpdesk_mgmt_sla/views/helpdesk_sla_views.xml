<odoo>
    <record id="view_helpdesk_sla_search" model="ir.ui.view">
        <field name="name">helpdesk.sla.form.search</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <search string="Helpdesk SLA Search">
                <filter
                    string="Archived"
                    name="inactive"
                    domain="[('active','=',False)]"
                />
                <separator />
                <field name="name" filter_domain="[('name', 'ilike', self)]" />
            </search>
        </field>
    </record>

    <record model="ir.ui.view" id="helpdesk_ticket_sla_form">
        <field name="name">helpdesk.sla.form</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <form string="SLA">
                <sheet>
                    <widget
                        name="web_ribbon"
                        title="Archived"
                        bg_color="text-bg-danger"
                        invisible="active"
                    />
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <field
                            name="company_id"
                            placeholder="Leave blank for all companies."
                            options="{'no_create': True}"
                            groups="base.group_multi_company"
                        />
                        <group>
                            <separator colspan="2" string="Apply on" />
                            <field
                                name="team_ids"
                                widget="many2many_tags"
                                domain="(company_id and [('company_id','in',[company_id,False])]) or []"
                            />
                            <field name="category_ids" widget="many2many_tags" />
                            <field name="tag_ids" widget="many2many_tags" />
                            <field name="ignore_stage_ids" widget="many2many_tags" />
                            <field name="stage_id" />
                            <field
                                name="domain"
                                widget="domain"
                                options="{'model': 'helpdesk.ticket', 'in_dialog': True}"
                            />
                        </group>
                        <group string="Target">
                            <label for="days" string="Reach In" />
                            <div class="o_row">
                                <field name="days" />
                                days
                                <br />
                                <field name="hours" />
                                hours
                                <br />
                            </div>
                        </group>
                    </group>
                    <group string="Description">
                        <field
                            name="note"
                            placeholder="Description of the policy..."
                            nolabel="1"
                            colspan="2"
                        />
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    <record model="ir.ui.view" id="helpdesk_sla_tree">
        <field name="name">helpdesk.sla.tree</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="days" />
                <field name="hours" />
                <field name="note" />
                <field name="company_id" groups="base.group_multi_company" />
            </list>
        </field>
    </record>
    <record id="action_helpdesk_sla_tree" model="ir.actions.act_window">
        <field name="name">Helpdesk SLA</field>
        <field name="res_model">helpdesk.sla</field>
        <field name="path">helpdesk-sla</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem
        id="helpdesk_sla"
        name="SLA"
        parent="helpdesk_mgmt.helpdesk_ticket_config_main_menu"
        action="action_helpdesk_sla_tree"
        sequence="9"
    />
</odoo>
